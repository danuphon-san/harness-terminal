    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 Harness. Released under the MIT License.</string>
    <!-- Harness implements no non-exempt encryption of its own: TLS is the system's (Sparkle's
         HTTPS appcast), and ssh/telnet are launched as external tools, not bundled crypto. Declaring
         this avoids the export-compliance prompt and documents the exemption for distribution. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- Auto-activate the bundled "Symbols Nerd Font Mono" (Contents/Resources/Fonts/) at
         launch so Nerd Font / Powerline prompt glyphs (PUA codepoints) always have a coverage
         font even when the user's primary font isn't a Nerd Font — the renderer falls back to
         it for those ranges (see GlyphRasterizer.symbolFont). MIT-licensed; ships in Fonts/. -->
    <key>ATSApplicationFontsPath</key>
    <string>Fonts</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <!-- Sparkle auto-update. Appcast hosted on the website; updates are EdDSA-signed
         (the public key below; the private key lives in the release machine's keychain). -->
    <key>SUFeedURL</key>
    <string>https://harnesscli.dev/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string>3LBPx8Uv5L5ptqRqdCWovmUIPLxcDEPnivy8cOpIlH8=</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
</dict>
